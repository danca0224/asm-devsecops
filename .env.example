# ============================================================
# ASM — Attack Surface Manager — Variables de entorno
# Copiar este archivo como .env y completar los valores
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=asm_db
POSTGRES_USER=asm_user
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_FUERTE_AQUI

# --- API Gateway ---
JWT_SECRET_KEY=CAMBIAR_CLAVE_JWT_SECRETA_ALEATORIA_256_BITS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=asm
RABBITMQ_PASSWORD=CAMBIAR_PASSWORD_RABBITMQ
CELERY_BROKER_URL=amqp://asm:CAMBIAR_PASSWORD_RABBITMQ@rabbitmq:5672//

# --- Rutas de almacenamiento (montadas via volumen Docker) ---
REPORTS_DIR=/data/reportes
CONSOLIDATED_DIR=/data/consolidados

# --- Admin inicial (solo para creación inicial) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

# --- Docker Hub (para CI/CD) ---
DOCKER_HUB_USERNAME=TU_USUARIO_DOCKERHUB
